# ─── Database ──────────────────────────────────────────────────────
# Postgres (production-recommended)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/entix?schema=public"

# ─── Admin auth ────────────────────────────────────────────────────
ADMIN_JWT_SECRET="change-me-to-a-long-random-string"
ADMIN_EMAIL="admin@entix.jewellery"
ADMIN_PASSWORD="EntixAdmin@2026"

# ─── Razorpay (hooks only in v1) ───────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# ─── Shipping (Shiprocket / Delhivery) ─────────────────────────────
SHIPROCKET_EMAIL=""
SHIPROCKET_PASSWORD=""
DELHIVERY_API_TOKEN=""

# ─── Email + cron ──────────────────────────────────────────────────
RESEND_API_KEY=""
CRON_SECRET="change-me-to-a-long-random-string"

# ─── Feature flags (hidden in v1) ──────────────────────────────────
NEXT_PUBLIC_FEATURE_CONCIERGE="false"
NEXT_PUBLIC_FEATURE_TRYON="false"
NEXT_PUBLIC_FEATURE_WHATSAPP="false"
NEXT_PUBLIC_FEATURE_RECOMMENDER=