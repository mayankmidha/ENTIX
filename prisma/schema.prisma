// Entix Jewellery · Prisma schema
// Production target: PostgreSQL. For zero-friction local dev, swap provider
// to "sqlite" and DATABASE_URL to "file:./dev.db".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Catalogue ────────────────────────────────────────────────────
model Product {
  id              String             @id @default(cuid())
  slug            String             @unique
  title           String
  subtitle        String?
  description     String
  story           String?
  material        String?            // e.g. "18k Champagne Gold, Kundan"
  finish          String?
  gemstone        String?
  weightGrams     Float?
  dimensions      String?
  careInstructions String?
  priceInr        Int                // stored in paise-free rupees for readability
  compareAtInr    Int?
  currency        String             @default("INR")
  isActive        Boolean            @default(true)
  isFeatured      Boolean            @default(false)
  isBestseller    Boolean            @default(false)
  isNewArrival    Boolean            @default(false)
  occasion        String?            // wedding | festive | everyday | gifting
  sku             String             @unique
  metaTitle       String?
  metaDescription String?
  seoTitle        String?
  seoDescription  String?
  relatedProducts String[]           @default([])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  images          ProductImage[]
  variants        ProductVariant[]
  inventory       InventoryItem?
  collections     CollectionProduct[]
  orderItems      OrderItem[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  reviews         Review[]

  @@index([isActive, isFeatured])
  @@index([occasion])
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  url         String
  alt         String?
  position    Int      @default(0)
  isPrimary   Boolean  @default(false)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
}

model Collection {
  id          String              @id @default(cuid())
  slug        String              @unique
  title       String
  subtitle    String?
  description String?
  heroImage   String?
  accentImage String?
  theme       String?             // editorial theme token
  position    Int                 @default(0)
  isActive    Boolean             @default(true)
  products    CollectionProduct[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model CollectionProduct {
  collectionId String
  productId    String
  position     Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
  @@index([collectionId, position])
}

model InventoryItem {
  id          String   @id @default(cuid())
  productId   String   @unique
  stockQty    Int      @default(0)
  lowStockAt  Int      @default(3)
  trackStock  Boolean  @default(true)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  updatedAt   DateTime @updatedAt
}

// ─── Customers & addresses ────────────────────────────────────────
model Customer {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  firstName    String?
  lastName     String?
  phone        String?
  marketingOk  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  addresses    Address[]
  orders       Order[]
  carts        Cart[]
  wishlists    Wishlist[]
}

model Address {
  id          String   @id @default(cuid())
  customerId  String
  name        String
  line1       String
  line2       String?
  city        String
  state       String
  postalCode  String
  country     String   @default("India")
  phone       String?
  isDefault   Boolean  @default(false)
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ─── Orders ──────────────────────────────────────────────────────
enum OrderStatus {
  pending
  paid
  processing
  shipped
  delivered
  returned
  refunded
  cancelled
}

enum PaymentStatus {
  pending
  authorized
  captured
  failed
  refunded
}

model Order {
  id               String        @id @default(cuid())
  orderNumber      String        @unique
  customerId       String?
  email            String
  phone            String?
  status           OrderStatus   @default(pending)
  paymentStatus    PaymentStatus @default(pending)
  subtotalInr      Int
  shippingInr      Int           @default(0)
  taxInr           Int           @default(0)
  totalInr         Int
  currency         String        @default("INR")
  shippingName     String
  shippingLine1    String
  shippingLine2    String?
  shippingCity     String
  shippingState    String
  shippingPostal   String
  shippingCountry  String        @default("India")
  shippingPhone    String?
  razorpayOrderId  String?
  razorpayPaymentId String?
  shiprocketOrderId String?
  trackingNumber   String?
  giftWrap         Boolean       @default(false)
  giftMessage      String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  customer   Customer?   @relation(fields: [customerId], references: [id])
  items      OrderItem[]

  @@index([status, createdAt])
}

model ProductVariant {
  id            String  @id @default(cuid())
  productId     String
  title         String  // e.g. "12 / Gold"
  sku           String? @unique
  priceInr      Int?    // Override base price if needed
  stockQty      Int     @default(0)
  compareAtInr  Int?    @default(0)
  barcode       String? @default("")
  weight        Float?  @default(0)
  dimensions    String? @default("")
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  variantId  String?
  title      String
  sku        String
  priceInr   Int
  quantity   Int
  imageUrl   String?
  engraving  String?
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])
}

// ─── Cart & wishlist ─────────────────────────────────────────────
model Cart {
  id          String     @id @default(cuid())
  sessionId   String     @unique
  customerId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  items       CartItem[]
  customer    Customer?  @relation(fields: [customerId], references: [id])
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model Wishlist {
  id          String         @id @default(cuid())
  sessionId   String         @unique
  customerId  String?
  createdAt   DateTime       @default(now())
  items       WishlistItem[]
  customer    Customer?      @relation(fields: [customerId], references: [id])
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  createdAt  DateTime @default(now())
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  @@unique([wishlistId, productId])
}

// ─── CMS / Site config ───────────────────────────────────────────
model PageContent {
  id        String   @id @default(cuid())
  key       String   @unique      // home.hero | home.story-1 | about.intro
  title     String?
  body      String?
  imageUrl  String?
  data      Json?
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id            String  @id @default(cuid())
  key           String  @unique  // e.g. announcement.message
  value         String
  description   String?
}

model PaymentProviderSetting {
  id        String  @id @default(cuid())
  provider  String  @unique      // razorpay | stripe | cod
  enabled   Boolean @default(false)
  keyId     String?
  keySecret String?
  mode      String  @default("test")
  updatedAt DateTime @updatedAt
}

model ShippingProviderSetting {
  id         String  @id @default(cuid())
  provider   String  @unique     // shiprocket | delhivery | manual
  enabled    Boolean @default(false)
  apiKey     String?
  apiSecret  String?
  accountId  String?
  updatedAt  DateTime @updatedAt
}

// ─── Admin & activity ────────────────────────────────────────────
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("admin") // owner | admin | operator | staff
  avatar       String?
  createdAt    DateTime @default(now())
  lastLoginAt  DateTime?
  activities   ActivityLog[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String   // e.g. "product.update", "order.refund", "discount.create"
  subject   String?  // e.g. productId, orderNumber
  detail    Json?
  createdAt DateTime @default(now())
  actor     AdminUser? @relation(fields: [actorId], references: [id])

  @@index([action, createdAt])
}

// ─── Discounts ──────────────────────────────────────────────────
enum DiscountType {
  percentage
  fixed_amount
  free_shipping
  buy_x_get_y
}

enum DiscountStatus {
  draft
  active
  scheduled
  expired
}

model Discount {
  id              String         @id @default(cuid())
  code            String         @unique
  title           String
  type            DiscountType
  valueInr        Int            @default(0)     // amount or percent (0–100)
  minSubtotalInr  Int?
  appliesTo       String         @default("all") // all | collection | product
  collectionId    String?
  productIds      String[]       @default([])
  usageLimit      Int?
  perCustomerLimit Int?
  timesUsed       Int            @default(0)
  startsAt        DateTime       @default(now())
  endsAt          DateTime?
  status          DiscountStatus @default(active)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status, endsAt])
}

// ─── Reviews ────────────────────────────────────────────────────
enum ReviewStatus {
  pending
  approved
  rejected
  spam
}

model Review {
  id          String       @id @default(cuid())
  productId   String
  customerId  String?
  authorName  String
  rating      Int          // 1-5
  title       String?
  body        String
  status      ReviewStatus @default(pending)
  helpfulCount Int         @default(0)
  mediaUrls   String[]     @default([])
  createdAt   DateTime     @default(now())
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, status])
}

// ─── Content: blog & media ──────────────────────────────────────
enum BlogStatus {
  draft
  published
  archived
}

model BlogPost {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String?
  body        String
  coverImage  String?
  authorName  String     @default("The Atelier")
  tags        String[]   @default([])
  status      BlogStatus @default(draft)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model MediaFile {
  id          String   @id @default(cuid())
  name        String
  url         String
  altText     String?
  kind        String   @default("image")   // image | video | document
  sizeBytes   Int?
  width       Int?
  height      Int?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
}

// ─── SEO: redirects ─────────────────────────────────────────────
model Redirect {
  id          String   @id @default(cuid())
  fromPath    String   @unique   // e.g. /old-slug
  toPath      String              // e.g. /collections/spring-26
  statusCode  Int      @default(301)
  createdAt   DateTime @default(now())
}

// ─── Shipping zones & rates ─────────────────────────────────────
model ShippingZone {
  id        String         @id @default(cuid())
  name      String
  countries String[]       @default([])
  states    String[]       @default([])
  rates     ShippingRate[]
  createdAt DateTime       @default(now())
}

enum ShippingRateKind {
  flat
  weight_based
  price_based
  free
}

model ShippingRate {
  id           String           @id @default(cuid())
  zoneId       String
  name         String
  kind         ShippingRateKind @default(flat)
  priceInr     Int              @default(0)
  minOrderInr  Int?
  maxOrderInr  Int?
  etaDays      Int?
  active       Boolean          @default(true)
  zone         ShippingZone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
}

// ─── Tax rates ──────────────────────────────────────────────────
model TaxRate {
  id          String   @id @default(cuid())
  name        String   // e.g. "GST 18% – Apparel"
  country     String   @default("IN")
  state       String?
  percent     Float
  hsn         String?  // HSN/SAC code
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── Email templates ────────────────────────────────────────────
model EmailTemplate {
  id         String   @id @default(cuid())
  key        String   @unique // order.confirmation | order.shipped | cart.abandoned | customer.welcome
  subject    String
  bodyHtml   String
  bodyText   String?
  fromName   String   @default("Entix Jewellery")
  fromEmail  String   @default("concierge@entix.jewellery")
  active     Boolean  @default(true)
  updatedAt  DateTime @updatedAt
}

// ─── Marketing ──────────────────────────────────────────────────
enum CampaignStatus {
  draft
  scheduled
  sending
  sent
  paused
}

enum CampaignChannel {
  email
  sms
  whatsapp
}

model MarketingCampaign {
  id           String         @id @default(cuid())
  name         String
  channel      CampaignChannel @default(email)
  subject      String?
  body         String
  audience     String         @default("all") // all | segment id
  status       CampaignStatus @default(draft)
  scheduledAt  DateTime?
  sentAt       DateTime?
  recipientCount Int          @default(0)
  openCount    Int            @default(0)
  clickCount   Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model CustomerSegment {
  id          String   @id @default(cuid())
  name        String
  description String?
  rule        Json     // e.g. { spentAbove: 10000, marketingOk: true }
  createdAt   DateTime @default(now())
}

// ─── Draft orders / quotes ──────────────────────────────────────
enum DraftOrderStatus {
  open
  invoice_sent
  completed
  cancelled
}

model DraftOrder {
  id          String           @id @default(cuid())
  name        String           // e.g. "#D-0001"
  customerEmail String?
  customerName  String?
  notes       String?
  lineItems   Json             // [{productId, title, sku, priceInr, quantity}]
  totalInr    Int              @default(0)
  status      DraftOrderStatus @default(open)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// ─── Abandoned checkouts ────────────────────────────────────────
model AbandonedCheckout {
  id                   String    @id @default(cuid())
  email                String?
  phone                String?
  customerName         String?
  cartJson             Json
  subtotalInr          Int
  recoveredOrderId     String?
  recoveryEmailSent    Boolean   @default(false)
  recoveryEmailSentAt  DateTime?
  createdAt            DateTime  @default(now())
  recoveredAt          DateTime?

  @@index([recoveredAt, createdAt])
  @@index([recoveryEmailSent, createdAt])
}

// ─── Gift cards ─────────────────────────────────────────────────
enum GiftCardStatus {
  active
  redeemed
  expired
  disabled
}

model GiftCard {
  id             String         @id @default(cuid())
  code           String         @unique
  initialInr     Int
  balanceInr     Int
  recipientEmail String?
  message        String?
  status         GiftCardStatus @default(active)
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Stock notifications ────────────────────────────────────────
model StockNotification {
  id        String   @id @default(cuid())
  email     String
  productId String
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([email, productId])
  @@index([productId, notified])
}

// ─── Analytics events ───────────────────────────────────────────
model AnalyticsEvent {
  id         String   @id @default(cuid())
  kind       String   // pageview | product_view | add_to_cart | checkout_start | order_placed
  path       String?
  productId  String?
  amountInr  Int?
  customerId String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([kind, createdAt])
}
